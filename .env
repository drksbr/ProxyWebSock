INTRATUN_ACME_HOST=relay.dontpad.com.br
INTRATUN_ACME_EMAIL=relay@dontpad.com.br
INTRATUN_DASHBOARD_USER=admin
INTRATUN_DASHBOARD_PASS=admin123

# Descomente para rodar atrás de um reverse proxy (Traefik/Nginx) sem TLS gerenciado pelo relay.
# Quando definido, ACME/Let's Encrypt é desabilitado e o serviço escuta em plain HTTP nesta porta.
# INTRATUN_PLAIN_LISTEN=:8443
